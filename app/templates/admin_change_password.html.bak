{% extends "base.html" %}

{% block title %}Change Password - Admin Panel{% endblock %}

{% block content %}
<div class="row mb-4 fade-in">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="brand-title mb-1">Change Password</h2>
                <p class="text-muted mb-0">Update password for user: <strong class="text-primary">{{
                        target_user.username }}</strong></p>
            </div>
            <a href="/admin/users" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to Users
            </a>
        </div>
    </div>
</div>

<div class="row justify-content-center fade-in">
    <div class="col-lg-5 col-md-8">
        <div class="card shadow-xl border-0">
            <div class="card-body p-4 p-md-5">
                <form method="POST" action="/admin/users/{{ target_user.id }}/password">

                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3 shadow-sm"
                            style="width: 80px; height: 80px; background: linear-gradient(135deg, #f093fb, #f5576c);">
                            <i class="fas fa-key fa-2x text-white"></i>
                        </div>
                        <h4 class="mb-1">Reset Password</h4>
                        <p class="text-muted small">Enter a new secure password</p>
                    </div>

                    <!-- New Password -->
                    <div class="mb-4">
                        <label for="new_password" class="form-label fw-bold small text-uppercase text-muted">New
                            Password <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i
                                    class="fas fa-lock text-muted"></i></span>
                            <input type="password" class="form-control border-start-0 ps-0 form-control-lg"
                                id="new_password" name="new_password" placeholder="New Password" required>
                        </div>
                    </div>

                    <!-- Submit -->
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary shadow-lg btn-lg">
                            <i class="fas fa-save me-2"></i>Update Password
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}