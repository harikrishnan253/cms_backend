{% extends "base.html" %}

{% block title %}User Management - Admin{% endblock %}

{% block content %}
<div class="row mb-4 fade-in">
    <div class="col-12">
        <div
            class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <div>
                <h2 class="brand-title mb-1">User Management</h2>
                <p class="text-muted mb-0">Manage system users, roles, and permissions</p>
            </div>
            <div class="d-flex gap-2">
                <a href="/admin" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Back
                </a>
                <a href="/admin/users/create" class="btn btn-primary shadow-sm">
                    <i class="fas fa-user-plus me-1"></i>Create New User
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-xl border-0 fade-in">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 text-muted small text-uppercase">User</th>
                        <th class="text-muted small text-uppercase">Role</th>
                        <th class="text-muted small text-uppercase">Status</th>
                        <th class="text-muted small text-uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for u in users %}
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold me-3 shadow-sm"
                                    style="width: 40px; height: 40px; background: linear-gradient(135deg, #667eea, #764ba2);">
                                    {{ u.username[0]|upper }}
                                </div>
                                <div>
                                    <div class="fw-bold text-dark">{{ u.username }}</div>
                                    <div class="small text-muted">{{ u.email }}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <form action="/admin/users/{{ u.id }}/role" method="post" class="d-flex align-items-center">
                                <select name="role_id" class="form-select form-select-sm shadow-sm"
                                    style="width: 150px;" onchange="this.form.submit()" {% if u.id==current_user.id
                                    %}disabled{% endif %}>
                                    {% for r in all_roles %}
                                    <option value="{{ r.id }}" {% if u.roles and u.roles[0].id==r.id %}selected{% endif
                                        %}>
                                        {{ r.name }}
                                    </option>
                                    {% endfor %}
                                </select>
                            </form>
                        </td>
                        <td>
                            {% if u.is_active %}
                            <span class="badge bg-success shadow-sm"><i
                                    class="fas fa-check-circle me-1"></i>Active</span>
                            {% else %}
                            <span class="badge bg-danger shadow-sm"><i class="fas fa-ban me-1"></i>Inactive</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if u.id != current_user.id %}
                            <div class="d-flex gap-1 justify-content-end">
                                <a href="/admin/users/{{ u.id }}/password"
                                    class="btn btn-sm btn-outline-warning shadow-sm" title="Change Password">
                                    <i class="fas fa-key"></i>
                                </a>
                                <form action="/admin/users/{{ u.id }}/status" method="post" class="d-inline">
                                    {% if u.is_active %}
                                    <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm"
                                        title="Deactivate">
                                        <i class="fas fa-user-slash"></i>
                                    </button>
                                    {% else %}
                                    <button type="submit" class="btn btn-sm btn-outline-success shadow-sm"
                                        title="Activate">
                                        <i class="fas fa-user-check"></i>
                                    </button>
                                    {% endif %}
                                </form>
                            </div>
                            {% else %}
                            <span class="text-muted small">Current User</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}