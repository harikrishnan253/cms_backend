{% extends "base.html" %}

{% block title %}Recent Activities - S4carlisle CMS{% endblock %}

{% block content %}
<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-6 fw-bold mb-2">
                        <i class="fas fa-history me-3 text-primary"></i>Recent Activities
                    </h1>
                    <p class="text-muted mb-0">Track all file uploads, processing, and system activities</p>
                </div>
                <div>
                    <a href="/dashboard" class="btn btn-outline-primary">
                        <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                style="width: 48px; height: 48px; background: linear-gradient(135deg, #667eea, #764ba2);">
                                <i class="fas fa-list text-white"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <div class="text-muted small">Total Activities</div>
                            <div class="h4 mb-0 fw-bold">{{ activities|length }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                style="width: 48px; height: 48px; background: linear-gradient(135deg, #43e97b, #38f9d7);">
                                <i class="fas fa-file-upload text-white"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <div class="text-muted small">File Uploads</div>
                            <div class="h4 mb-0 fw-bold">{{ activities|selectattr('type', 'equalto',
                                'upload')|list|length }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                style="width: 48px; height: 48px; background: linear-gradient(135deg, #fa709a, #fee140);">
                                <i class="fas fa-cogs text-white"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <div class="text-muted small">Processing</div>
                            <div class="h4 mb-0 fw-bold">{{ activities|selectattr('type', 'equalto',
                                'version')|list|length }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                style="width: 48px; height: 48px; background: linear-gradient(135deg, #f093fb, #f5576c);">
                                <i class="fas fa-clock text-white"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <div class="text-muted small">Today</div>
                            <div class="h4 mb-0 fw-bold">{{ today_count }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Activity Timeline -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="fas fa-stream me-2 text-primary"></i>Activity Timeline
                    </h5>
                </div>
                <div class="card-body p-0">
                    {% if activities %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th width="5%" class="border-0 py-3 ps-4">
                                        <i class="fas fa-circle" style="font-size: 0.5rem;"></i>
                                    </th>
                                    <th width="20%" class="border-0 py-3">Activity</th>
                                    <th width="25%" class="border-0 py-3">Description</th>
                                    <th width="15%" class="border-0 py-3">Project</th>
                                    <th width="15%" class="border-0 py-3">Chapter</th>
                                    <th width="10%" class="border-0 py-3">Category</th>
                                    <th width="10%" class="border-0 py-3 text-end pe-4">Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for activity in activities %}
                                <tr class="activity-row">
                                    <td class="ps-4">
                                        {% if activity.type == 'upload' %}
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                            style="width: 32px; height: 32px; background: linear-gradient(135deg, #667eea, #764ba2);">
                                            <i class="fas {{ activity.icon }} text-white"
                                                style="font-size: 0.8rem;"></i>
                                        </div>
                                        {% else %}
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                            style="width: 32px; height: 32px; background: linear-gradient(135deg, #43e97b, #38f9d7);">
                                            <i class="fas {{ activity.icon }} text-white"
                                                style="font-size: 0.8rem;"></i>
                                        </div>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark">{{ activity.title }}</div>
                                        <div class="small text-muted">
                                            {% if activity.type == 'upload' %}
                                            <i class="fas fa-upload me-1"></i>New file
                                            {% else %}
                                            <i class="fas fa-cogs me-1"></i>Processed
                                            {% endif %}
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 250px;"
                                            title="{{ activity.description }}">
                                            <i class="fas fa-file me-2 text-muted"></i>{{ activity.description }}
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            <i class="fas fa-book me-1"></i>{{ activity.project }}
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            <i class="fas fa-bookmark me-1"></i>{{ activity.chapter }}
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge 
                                            {% if activity.category == 'Manuscript' %}bg-primary
                                            {% elif activity.category == 'Art' %}bg-success
                                            {% elif activity.category == 'InDesign' %}bg-danger
                                            {% elif activity.category == 'Proof' %}bg-warning text-dark
                                            {% elif activity.category == 'XML' %}bg-info
                                            {% else %}bg-secondary{% endif %}">
                                            {{ activity.category }}
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="small text-muted">
                                            <i class="far fa-clock me-1"></i>{{ activity.time }}
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-5">
                        <i class="fas fa-inbox fa-3x text-muted mb-3 opacity-25"></i>
                        <p class="text-muted mb-0">No activities found</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .activity-row {
        transition: all 0.2s ease;
    }

    .activity-row:hover {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
        transform: translateX(2px);
    }

    .card {
        transition: all 0.3s ease;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>
{% endblock %}