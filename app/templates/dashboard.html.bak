<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Publishing Production CMS</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- <script src="/_sdk/element_sdk.js"></script> -->
  <!-- <script src="/_sdk/data_sdk.js"></script> -->
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
  <style>
    body {
      box-sizing: border-box;
    }
    * {
      font-family: 'DM Sans', sans-serif;
    }
    .sidebar-item:hover {
      background: rgba(255,255,255,0.1);
    }
    .sidebar-item.active {
      background: rgba(255,255,255,0.15);
      border-left: 3px solid #10b981;
    }
    .stage-card {
      transition: all 0.2s ease;
    }
    .stage-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }
    .status-badge {
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }
    .progress-fill {
      transition: width 0.5s ease;
    }
    .kanban-column {
      min-height: 200px;
    }
    .metric-card {
      transition: transform 0.2s ease;
    }
    .metric-card:hover {
      transform: scale(1.02);
    }
    .modal-overlay {
      animation: fadeIn 0.2s ease;
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    .toast {
      animation: slideIn 0.3s ease;
    }
    @keyframes slideIn {
      from { transform: translateX(100%); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }
  </style>
  <style>@view-transition { navigation: auto; }</style>
 </head>
 <body class="h-full bg-slate-50 overflow-auto">
  <div id="app" class="h-full w-full flex"><!-- Sidebar -->
   <aside id="sidebar" class="w-64 bg-slate-900 text-white flex-shrink-0 flex flex-col">
    <div class="p-6 border-b border-slate-700">
     <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-emerald-500 flex items-center justify-center">
       <svg class="w-6 h-6" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
       </svg>
      </div>
      <div>
       <h1 id="sidebar-title" class="font-bold text-lg">Pub CMS</h1>
       <p id="company-name" class="text-xs text-slate-400">Production Suite</p>
      </div>
     </div>
    </div>
    <nav class="flex-1 p-4 space-y-1"><button onclick="showView('dashboard')" class="sidebar-item active w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left" data-view="dashboard">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
      </svg> Dashboard </button> <button onclick="showView('projects')" class="sidebar-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left" data-view="projects">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg> Projects </button> <button onclick="showView('workflow')" class="sidebar-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left" data-view="workflow">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
      </svg> Workflow </button> <button onclick="showView('files')" class="sidebar-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left" data-view="files">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z" />
      </svg> Files </button> <button onclick="showView('quality')" class="sidebar-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left" data-view="quality">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg> Quality Control </button> <button onclick="showView('reports')" class="sidebar-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left" data-view="reports">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
      </svg> Reports </button>
    </nav>
    <div class="p-4 border-t border-slate-700">
     <div class="flex items-center gap-3 px-4 py-2">
      <div class="w-8 h-8 rounded-full bg-emerald-500 flex items-center justify-center text-sm font-semibold">
       PE
      </div>
      <div>
       <p class="text-sm font-medium">{{ user.username if user else 'Production Editor' }}</p>
       <p class="text-xs text-slate-400">{{ user.roles[0] if user and user.roles else 'Admin Access' }}</p>
      </div>
     </div>
    </div>
   </aside><!-- Main Content -->
   <main class="flex-1 overflow-auto"><!-- Dashboard View -->
    <div id="view-dashboard" class="view-content p-8">
     <div class="mb-8">
      <h2 id="dashboard-heading" class="text-3xl font-bold text-slate-800">Dashboard</h2>
      <p class="text-slate-500 mt-1">Publishing Production Overview</p>
     </div><!-- Metrics Row -->
     <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div class="metric-card bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
       <div class="flex items-center justify-between mb-4">
        <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center">
         <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
         </svg>
        </div><span class="text-xs font-medium text-emerald-600 bg-emerald-50 px-2 py-1 rounded-full">+12%</span>
       </div>
       <p class="text-3xl font-bold text-slate-800" id="total-projects">0</p>
       <p class="text-slate-500 text-sm">Total Projects</p>
      </div>
      <div class="metric-card bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
       <div class="flex items-center justify-between mb-4">
        <div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center">
         <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
         </svg>
        </div><span class="text-xs font-medium text-emerald-600 bg-emerald-50 px-2 py-1 rounded-full">94%</span>
       </div>
       <p class="text-3xl font-bold text-slate-800" id="on-time-rate">94%</p>
       <p class="text-slate-500 text-sm">On-Time Delivery</p>
      </div>
      <div class="metric-card bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
       <div class="flex items-center justify-between mb-4">
        <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center">
         <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
         </svg>
        </div><span class="text-xs font-medium text-amber-600 bg-amber-50 px-2 py-1 rounded-full">-2 days</span>
       </div>
       <p class="text-3xl font-bold text-slate-800">8.5</p>
       <p class="text-slate-500 text-sm">Avg. Days to Complete</p>
      </div>
      <div class="metric-card bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
       <div class="flex items-center justify-between mb-4">
        <div class="w-12 h-12 rounded-xl bg-rose-100 flex items-center justify-center">
         <svg class="w-6 h-6 text-rose-600" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
         </svg>
        </div><span class="text-xs font-medium text-rose-600 bg-rose-50 px-2 py-1 rounded-full" id="delayed-count">0</span>
       </div>
       <p class="text-3xl font-bold text-slate-800" id="delayed-projects">0</p>
       <p class="text-slate-500 text-sm">Delayed Projects</p>
      </div>
     </div><!-- Workflow Overview -->
     <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 mb-8">
      <h3 class="text-lg font-semibold text-slate-800 mb-6">Production Workflow Pipeline</h3>
      <div class="flex items-center justify-between overflow-x-auto pb-4">
       <div class="flex items-center gap-2 min-w-max">
        <div class="stage-card bg-slate-50 rounded-xl p-4 text-center min-w-[120px]">
         <div class="w-10 h-10 rounded-full bg-slate-200 flex items-center justify-center mx-auto mb-2"><span class="text-lg">📥</span>
         </div>
         <p class="text-xs font-medium text-slate-600">Received</p>
         <p class="text-lg font-bold text-slate-800" id="stage-received">0</p>
        </div>
        <svg class="w-6 h-6 text-slate-300 flex-shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <div class="stage-card bg-blue-50 rounded-xl p-4 text-center min-w-[120px]">
         <div class="w-10 h-10 rounded-full bg-blue-200 flex items-center justify-center mx-auto mb-2"><span class="text-lg">✏️</span>
         </div>
         <p class="text-xs font-medium text-blue-600">Copyediting</p>
         <p class="text-lg font-bold text-blue-800" id="stage-copyediting">0</p>
        </div>
        <svg class="w-6 h-6 text-slate-300 flex-shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <div class="stage-card bg-violet-50 rounded-xl p-4 text-center min-w-[120px]">
         <div class="w-10 h-10 rounded-full bg-violet-200 flex items-center justify-center mx-auto mb-2"><span class="text-lg">🔤</span>
         </div>
         <p class="text-xs font-medium text-violet-600">Typesetting</p>
         <p class="text-lg font-bold text-violet-800" id="stage-typesetting">0</p>
        </div>
        <svg class="w-6 h-6 text-slate-300 flex-shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <div class="stage-card bg-amber-50 rounded-xl p-4 text-center min-w-[120px]">
         <div class="w-10 h-10 rounded-full bg-amber-200 flex items-center justify-center mx-auto mb-2"><span class="text-lg">📄</span>
         </div>
         <p class="text-xs font-medium text-amber-600">Proofing</p>
         <p class="text-lg font-bold text-amber-800" id="stage-proofing">0</p>
        </div>
        <svg class="w-6 h-6 text-slate-300 flex-shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <div class="stage-card bg-teal-50 rounded-xl p-4 text-center min-w-[120px]">
         <div class="w-10 h-10 rounded-full bg-teal-200 flex items-center justify-center mx-auto mb-2"><span class="text-lg">🔍</span>
         </div>
         <p class="text-xs font-medium text-teal-600">Final QC</p>
         <p class="text-lg font-bold text-teal-800" id="stage-qc">0</p>
        </div>
        <svg class="w-6 h-6 text-slate-300 flex-shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <div class="stage-card bg-emerald-50 rounded-xl p-4 text-center min-w-[120px]">
         <div class="w-10 h-10 rounded-full bg-emerald-200 flex items-center justify-center mx-auto mb-2"><span class="text-lg">✅</span>
         </div>
         <p class="text-xs font-medium text-emerald-600">Completed</p>
         <p class="text-lg font-bold text-emerald-800" id="stage-completed">0</p>
        </div>
       </div>
      </div>
     </div><!-- Responsibility Matrix -->
     <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
      <h3 class="text-lg font-semibold text-slate-800 mb-6">Role-Based Responsibility Matrix</h3>
      <div class="overflow-x-auto">
       <table class="w-full">
        <thead>
         <tr class="border-b border-slate-100">
          <th class="text-left py-3 px-4 text-sm font-semibold text-slate-600">Stage</th>
          <th class="text-left py-3 px-4 text-sm font-semibold text-slate-600">Responsible</th>
          <th class="text-left py-3 px-4 text-sm font-semibold text-slate-600">SLA</th>
          <th class="text-left py-3 px-4 text-sm font-semibold text-slate-600">Status</th>
         </tr>
        </thead>
        <tbody>
         <tr class="border-b border-slate-50 hover:bg-slate-50">
          <td class="py-3 px-4">
           <div class="flex items-center gap-2"><span class="text-lg">✏️</span> <span class="font-medium text-slate-700">Copyediting</span>
           </div></td>
          <td class="py-3 px-4">
           <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center text-xs">
             👤
            </div><span class="text-slate-600">CE Vendor</span>
           </div></td>
          <td class="py-3 px-4 text-slate-600">3 days</td>
          <td class="py-3 px-4"><span class="px-2 py-1 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Active</span></td>
         </tr>
         <tr class="border-b border-slate-50 hover:bg-slate-50">
          <td class="py-3 px-4">
           <div class="flex items-center gap-2"><span class="text-lg">🔤</span> <span class="font-medium text-slate-700">Typesetting</span>
           </div></td>
          <td class="py-3 px-4">
           <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-full bg-violet-100 flex items-center justify-center text-xs">
             👥
            </div><span class="text-slate-600">Composition Team</span>
           </div></td>
          <td class="py-3 px-4 text-slate-600">2 days</td>
          <td class="py-3 px-4"><span class="px-2 py-1 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Active</span></td>
         </tr>
         <tr class="border-b border-slate-50 hover:bg-slate-50">
          <td class="py-3 px-4">
           <div class="flex items-center gap-2"><span class="text-lg">📄</span> <span class="font-medium text-slate-700">Proof Review</span>
           </div></td>
          <td class="py-3 px-4">
           <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-full bg-amber-100 flex items-center justify-center text-xs">
             ✍️
            </div><span class="text-slate-600">Author</span>
           </div></td>
          <td class="py-3 px-4 text-slate-600">5 days</td>
          <td class="py-3 px-4"><span class="px-2 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-700">Pending</span></td>
         </tr>
         <tr class="border-b border-slate-50 hover:bg-slate-50">
          <td class="py-3 px-4">
           <div class="flex items-center gap-2"><span class="text-lg">🔍</span> <span class="font-medium text-slate-700">Quality Control</span>
           </div></td>
          <td class="py-3 px-4">
           <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-full bg-teal-100 flex items-center justify-center text-xs">
             👤
            </div><span class="text-slate-600">Production Editor</span>
           </div></td>
          <td class="py-3 px-4 text-slate-600">1 day</td>
          <td class="py-3 px-4"><span class="px-2 py-1 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Active</span></td>
         </tr>
         <tr class="hover:bg-slate-50">
          <td class="py-3 px-4">
           <div class="flex items-center gap-2"><span class="text-lg">📦</span> <span class="font-medium text-slate-700">Delivery</span>
           </div></td>
          <td class="py-3 px-4">
           <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center text-xs">
             👤
            </div><span class="text-slate-600">Project Manager</span>
           </div></td>
          <td class="py-3 px-4 text-slate-600">1 day</td>
          <td class="py-3 px-4"><span class="px-2 py-1 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Active</span></td>
         </tr>
        </tbody>
       </table>
      </div>
     </div>
    </div><!-- Projects View -->
    <div id="view-projects" class="view-content hidden p-8">
     <div class="flex items-center justify-between mb-8">
      <div>
       <h2 class="text-3xl font-bold text-slate-800">Projects</h2>
       <p class="text-slate-500 mt-1">Manage manuscript assignments</p>
      </div><button onclick="openProjectModal()" class="flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-xl font-medium transition-colors">
       <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
       </svg> New Project </button>
     </div><!-- Filter Bar -->
     <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-100 mb-6 flex flex-wrap gap-4 items-center">
      <div class="flex items-center gap-2"><label for="filter-status" class="text-sm text-slate-600">Status:</label> <select id="filter-status" onchange="filterProjects()" class="border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500"> <option value="all">All</option> <option value="Not Started">Not Started</option> <option value="In Progress">In Progress</option> <option value="On Hold">On Hold</option> <option value="With Author">With Author</option> <option value="Completed">Completed</option> <option value="Delayed">Delayed</option> </select>
      </div>
      <div class="flex items-center gap-2"><label for="filter-client" class="text-sm text-slate-600">Client:</label> <select id="filter-client" onchange="filterProjects()" class="border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500"> <option value="all">All Clients</option> <option value="Springer">Springer</option> <option value="Elsevier">Elsevier</option> <option value="Wiley">Wiley</option> <option value="Taylor &amp; Francis">Taylor &amp; Francis</option> </select>
      </div>
      <div class="flex-1"></div>
      <div class="relative">
       <svg class="w-5 h-5 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
       </svg><input type="text" id="search-projects" oninput="filterProjects()" placeholder="Search projects..." class="pl-10 pr-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 w-64">
      </div>
     </div><!-- Projects Table -->
     <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
      <div class="overflow-x-auto">
       <table class="w-full">
        <thead class="bg-slate-50">
         <tr>
          <th class="text-left py-4 px-6 text-sm font-semibold text-slate-600">Project</th>
          <th class="text-left py-4 px-6 text-sm font-semibold text-slate-600">Client</th>
