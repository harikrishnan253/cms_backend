          <td class="py-3 px-4"><span class="px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Good</span></td>
         </tr>
         <tr class="hover:bg-slate-50">
          <td class="py-3 px-4 font-medium text-slate-700">XML Solutions</td>
          <td class="py-3 px-4 text-slate-600">52</td>
          <td class="py-3 px-4"><span class="text-amber-600 font-semibold">85%</span></td>
          <td class="py-3 px-4">
           <div class="flex items-center gap-1"><span class="text-amber-500">★★★☆☆</span>
           </div></td>
          <td class="py-3 px-4 text-slate-600">15%</td>
          <td class="py-3 px-4"><span class="px-2 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-700">Average</span></td>
         </tr>
        </tbody>
       </table>
      </div>
     </div>
    </div>
   </main>
  </div><!-- Project Modal -->
  <div id="project-modal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden modal-overlay">
   <div class="bg-white rounded-2xl w-full max-w-2xl max-h-[90%] overflow-auto m-4">
    <div class="p-6 border-b border-slate-100 flex items-center justify-between">
     <h3 id="modal-title" class="text-xl font-semibold text-slate-800">New Project</h3><button onclick="closeProjectModal()" class="w-8 h-8 rounded-lg hover:bg-slate-100 flex items-center justify-center">
      <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg></button>
    </div>
    <form id="project-form" onsubmit="handleProjectSubmit(event)" class="p-6 space-y-6"><input type="hidden" id="edit-project-id">
     <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div><label for="project-id" class="block text-sm font-medium text-slate-700 mb-2">Project ID</label> <input type="text" id="project-id" required placeholder="PUB-2024-XXX" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500">
      </div>
      <div><label for="isbn" class="block text-sm font-medium text-slate-700 mb-2">ISBN / DOI</label> <input type="text" id="isbn" placeholder="978-X-XXX-XXXXX-X" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500">
      </div>
     </div>
     <div><label for="title" class="block text-sm font-medium text-slate-700 mb-2">Title</label> <input type="text" id="title" required placeholder="Manuscript title" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500">
     </div>
     <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div><label for="client" class="block text-sm font-medium text-slate-700 mb-2">Client</label> <select id="client" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500"> <option value="">Select client</option> <option value="Springer">Springer</option> <option value="Elsevier">Elsevier</option> <option value="Wiley">Wiley</option> <option value="Taylor &amp; Francis">Taylor &amp; Francis</option> </select>
      </div>
      <div><label for="manuscript-type" class="block text-sm font-medium text-slate-700 mb-2">Manuscript Type</label> <select id="manuscript-type" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500"> <option value="">Select type</option> <option value="Book">Book</option> <option value="Chapter">Chapter</option> <option value="Journal">Journal Article</option> </select>
      </div>
     </div>
     <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div><label for="start-date" class="block text-sm font-medium text-slate-700 mb-2">Start Date</label> <input type="date" id="start-date" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500">
      </div>
      <div><label for="due-date" class="block text-sm font-medium text-slate-700 mb-2">Due Date</label> <input type="date" id="due-date" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500">
      </div>
     </div>
     <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div><label for="assigned-pe" class="block text-sm font-medium text-slate-700 mb-2">Assigned PE</label> <select id="assigned-pe" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500"> <option value="">Select PE</option> <option value="Sarah Johnson">Sarah Johnson</option> <option value="Michael Chen">Michael Chen</option> <option value="Emily Davis">Emily Davis</option> <option value="James Wilson">James Wilson</option> </select>
      </div>
      <div><label for="current-stage" class="block text-sm font-medium text-slate-700 mb-2">Current Stage</label> <select id="current-stage" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500"> <option value="Received">Manuscript Received</option> <option value="Copyediting">Copyediting</option> <option value="Typesetting">Typesetting</option> <option value="Proofing">Proofing</option> <option value="Final QC">Final QC</option> <option value="Completed">Completed</option> </select>
      </div>
     </div>
     <div><label for="status" class="block text-sm font-medium text-slate-700 mb-2">Status</label> <select id="status" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500"> <option value="Not Started">Not Started</option> <option value="In Progress">In Progress</option> <option value="On Hold">On Hold</option> <option value="With Author">With Author</option> <option value="Completed">Completed</option> <option value="Delayed">Delayed</option> </select>
     </div>
     <div class="flex items-center justify-end gap-3 pt-4"><button type="button" onclick="closeProjectModal()" class="px-5 py-2.5 border border-slate-200 rounded-xl text-slate-600 font-medium hover:bg-slate-50 transition-colors"> Cancel </button> <button type="submit" id="submit-btn" class="px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl font-medium transition-colors flex items-center gap-2"> <span id="submit-text">Create Project</span>
       <svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewbox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25" /> <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" class="opacity-75" />
       </svg></button>
     </div>
    </form>
   </div>
  </div><!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden modal-overlay">
   <div class="bg-white rounded-2xl w-full max-w-md m-4 p-6">
    <div class="flex items-center gap-4 mb-4">
     <div class="w-12 h-12 rounded-full bg-rose-100 flex items-center justify-center">
      <svg class="w-6 h-6 text-rose-600" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
     </div>
     <div>
      <h3 class="text-lg font-semibold text-slate-800">Delete Project</h3>
      <p class="text-sm text-slate-500">This action cannot be undone.</p>
     </div>
    </div>
    <p class="text-slate-600 mb-6">Are you sure you want to delete "<span id="delete-project-title" class="font-medium"></span>"?</p>
    <div class="flex items-center justify-end gap-3"><button onclick="closeDeleteModal()" class="px-4 py-2 border border-slate-200 rounded-xl text-slate-600 font-medium hover:bg-slate-50 transition-colors"> Cancel </button> <button onclick="confirmDelete()" id="confirm-delete-btn" class="px-4 py-2 bg-rose-600 hover:bg-rose-700 text-white rounded-xl font-medium transition-colors flex items-center gap-2"> <span>Delete</span>
      <svg id="delete-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewbox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25" /> <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" class="opacity-75" />
      </svg></button>
    </div>
   </div>
  </div><!-- Toast Container -->
  <div id="toast-container" class="fixed bottom-6 right-6 z-50 space-y-3"></div>
  <script>
    // Default config
    const defaultConfig = {
      dashboard_title: 'Publishing Production CMS',
      company_name: 'Production Suite',
      background_color: '#f8fafc',
      sidebar_color: '#0f172a',
      accent_color: '#10b981',
      text_color: '#334155',
      card_color: '#ffffff'
    };
    
    let config = { ...defaultConfig };
    
    // Inject projects from backend (Jinja2)
    let projects = [
      {% for project in projects %}
      {
        "__backendId": "{{ project.id }}",
        "project_id": "{{ project.code }}",
        "title": "{{ project.title }}",
        "client": "{{ project.client_name }}",
        "manuscript_type": "Book",
        "current_stage": "{% if project.status == 'RECEIVED' %}Received{% elif project.status == 'PROCESSING' %}Copyediting{% elif project.status == 'XML_GENERATED' %}Typesetting{% elif project.status == 'PUBLISHED' %}Completed{% else %}Received{% endif %}",
        "status": "{% if project.status == 'PUBLISHED' %}Completed{% else %}In Progress{% endif %}",
        "due_date": "", 
        "start_date": "",
        "isbn": "",
        "assigned_pe": ""
      }{{ "," if not loop.last }}
      {% endfor %}
    ];

    let projectToDelete = null;
    let isEditing = false;
    
    // Element SDK Init
    if (window.elementSdk) {
      window.elementSdk.init({
        defaultConfig,
        onConfigChange: async (newConfig) => {
          config = { ...defaultConfig, ...newConfig };
          applyConfig();
        },
        mapToCapabilities: (cfg) => ({
          recolorables: [
            {
              get: () => cfg.background_color || defaultConfig.background_color,
              set: (value) => { cfg.background_color = value; window.elementSdk.setConfig({ background_color: value }); }
            },
            {
              get: () => cfg.sidebar_color || defaultConfig.sidebar_color,
              set: (value) => { cfg.sidebar_color = value; window.elementSdk.setConfig({ sidebar_color: value }); }
            },
            {
              get: () => cfg.accent_color || defaultConfig.accent_color,
              set: (value) => { cfg.accent_color = value; window.elementSdk.setConfig({ accent_color: value }); }
            },
            {
              get: () => cfg.text_color || defaultConfig.text_color,
              set: (value) => { cfg.text_color = value; window.elementSdk.setConfig({ text_color: value }); }
            },
            {
              get: () => cfg.card_color || defaultConfig.card_color,
              set: (value) => { cfg.card_color = value; window.elementSdk.setConfig({ card_color: value }); }
            }
          ],
          borderables: [],
          fontEditable: undefined,
          fontSizeable: undefined
        }),
        mapToEditPanelValues: (cfg) => new Map([
          ['dashboard_title', cfg.dashboard_title || defaultConfig.dashboard_title],
          ['company_name', cfg.company_name || defaultConfig.company_name]
        ])
      });
    }
    
    function applyConfig() {
      document.getElementById('sidebar-title').textContent = config.dashboard_title || defaultConfig.dashboard_title;
      document.getElementById('company-name').textContent = config.company_name || defaultConfig.company_name;
      document.getElementById('dashboard-heading').textContent = config.dashboard_title || defaultConfig.dashboard_title;
    }
    
    // Data SDK Init
    const dataHandler = {
      onDataChanged(data) {
        projects = data;
        updateDashboard();
        renderProjectsTable();
        renderKanbanBoard();
      }
    };
    
    async function initDataSdk() {
      if (window.dataSdk) {
        const result = await window.dataSdk.init(dataHandler);
        if (!result.isOk) {
          showToast('Failed to initialize data storage', 'error');
        }
      } else {
        // Fallback: manually init view if SDK is missing
        updateDashboard();
        renderProjectsTable();
        renderKanbanBoard();
      }
    }
    
    initDataSdk();
    
    // View Management
    function showView(viewName) {
      document.querySelectorAll('.view-content').forEach(v => v.classList.add('hidden'));
      document.getElementById(`view-${viewName}`).classList.remove('hidden');
      
      document.querySelectorAll('.sidebar-item').forEach(item => {
        item.classList.remove('active');
        if (item.dataset.view === viewName) {
          item.classList.add('active');
        }
      });
    }
    
    // Dashboard Updates
    function updateDashboard() {
      const total = projects.length;
      const delayed = projects.filter(p => p.status === 'Delayed').length;
      const completed = projects.filter(p => p.current_stage === 'Completed').length;
      
      document.getElementById('total-projects').textContent = total;
      document.getElementById('delayed-projects').textContent = delayed;
      document.getElementById('delayed-count').textContent = delayed;
      
      // Stage counts
      const stageCounts = {
        'Received': 0,
        'Copyediting': 0,
        'Typesetting': 0,
        'Proofing': 0,
        'Final QC': 0,
        'Completed': 0
      };
      
      projects.forEach(p => {
        if (stageCounts.hasOwnProperty(p.current_stage)) {
          stageCounts[p.current_stage]++;
        }
      });
      
      document.getElementById('stage-received').textContent = stageCounts['Received'];
      document.getElementById('stage-copyediting').textContent = stageCounts['Copyediting'];
      document.getElementById('stage-typesetting').textContent = stageCounts['Typesetting'];
      document.getElementById('stage-proofing').textContent = stageCounts['Proofing'];
      document.getElementById('stage-qc').textContent = stageCounts['Final QC'];
      document.getElementById('stage-completed').textContent = stageCounts['Completed'];
    }
    
    // Projects Table
    function renderProjectsTable() {
      const tbody = document.getElementById('projects-table-body');
      const filterStatus = document.getElementById('filter-status').value;
      const filterClient = document.getElementById('filter-client').value;
      const searchTerm = document.getElementById('search-projects').value.toLowerCase();
      
      let filtered = projects.filter(p => {
        const matchStatus = filterStatus === 'all' || p.status === filterStatus;
        const matchClient = filterClient === 'all' || p.client === filterClient;
        const matchSearch = p.title.toLowerCase().includes(searchTerm) || 
                          p.project_id.toLowerCase().includes(searchTerm);
        return matchStatus && matchClient && matchSearch;
      });
      
      if (filtered.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="7" class="py-12 text-center text-slate-500">
              <div class="flex flex-col items-center">
                <svg class="w-12 h-12 text-slate-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <p class="font-medium">${projects.length === 0 ? 'No projects yet' : 'No matching projects'}</p>
                <p class="text-sm">${projects.length === 0 ? 'Click "New Project" to add your first assignment' : 'Try adjusting your filters'}</p>
              </div>
            </td>
          </tr>
        `;
        return;
      }
      
      tbody.innerHTML = filtered.map(p => `
        <tr class="border-b border-slate-50 hover:bg-slate-50">
          <td class="py-4 px-6">
            <div>
              <p class="font-medium text-slate-700">${escapeHtml(p.title)}</p>
              <p class="text-sm text-slate-500">${escapeHtml(p.project_id)}</p>
            </div>
          </td>
          <td class="py-4 px-6 text-slate-600">${escapeHtml(p.client)}</td>
          <td class="py-4 px-6">
            <span class="px-2 py-1 rounded-full text-xs font-medium ${getTypeClass(p.manuscript_type)}">${escapeHtml(p.manuscript_type)}</span>
          </td>
          <td class="py-4 px-6">
            <span class="px-2 py-1 rounded-full text-xs font-medium ${getStageClass(p.current_stage)}">${escapeHtml(p.current_stage)}</span>
          </td>
          <td class="py-4 px-6">
            <span class="px-2 py-1 rounded-full text-xs font-medium ${getStatusClass(p.status)}">${escapeHtml(p.status)}</span>
          </td>
          <td class="py-4 px-6 text-slate-600">${formatDate(p.due_date)}</td>
          <td class="py-4 px-6">
            <div class="flex items-center gap-2">
              <button onclick="editProject('${p.__backendId}')" class="w-8 h-8 rounded-lg hover:bg-slate-200 flex items-center justify-center text-slate-500 hover:text-slate-700">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
              </button>
              <button onclick="openDeleteModal('${p.__backendId}')" class="w-8 h-8 rounded-lg hover:bg-rose-100 flex items-center justify-center text-slate-500 hover:text-rose-600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
              </button>
            </div>
          </td>
        </tr>
      `).join('');
    }
    
    function filterProjects() {
      renderProjectsTable();
    }
    
    // Kanban Board
    function renderKanbanBoard() {
      const stages = {
        'Received': 'kanban-received',
        'Copyediting': 'kanban-copyediting',
        'Typesetting': 'kanban-typesetting',
        'Proofing': 'kanban-proofing',
        'Final QC': 'kanban-qc',
        'Completed': 'kanban-completed'
      };
      
      const counts = {};
      
      Object.keys(stages).forEach(stage => {
        const container = document.getElementById(stages[stage]);
        const stageProjects = projects.filter(p => p.current_stage === stage);
        counts[stage] = stageProjects.length;
        
        if (stageProjects.length === 0) {
          container.innerHTML = '<p class="text-sm text-slate-400 text-center py-4">No projects</p>';
        } else {
          container.innerHTML = stageProjects.map(p => `
            <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-100 cursor-pointer hover:shadow-md transition-shadow" onclick="editProject('${p.__backendId}')">
              <div class="flex items-start justify-between mb-2">
                <span class="text-xs font-medium text-slate-500">${escapeHtml(p.project_id)}</span>
                <span class="px-2 py-0.5 rounded-full text-xs font-medium ${getStatusClass(p.status)}">${escapeHtml(p.status)}</span>
              </div>
              <p class="font-medium text-slate-700 text-sm mb-2 line-clamp-2">${escapeHtml(p.title)}</p>
              <div class="flex items-center justify-between text-xs text-slate-500">
                <span>${escapeHtml(p.client)}</span>
                <span>Due: ${formatDate(p.due_date)}</span>
              </div>
            </div>
          `).join('');
        }
      });
      
      // Update counts
      document.getElementById('kanban-received-count').textContent = counts['Received'];
      document.getElementById('kanban-copyediting-count').textContent = counts['Copyediting'];
      document.getElementById('kanban-typesetting-count').textContent = counts['Typesetting'];
      document.getElementById('kanban-proofing-count').textContent = counts['Proofing'];
      document.getElementById('kanban-qc-count').textContent = counts['Final QC'];
      document.getElementById('kanban-completed-count').textContent = counts['Completed'];
    }
    
    // Modal Functions
    function openProjectModal() {
      isEditing = false;
      document.getElementById('modal-title').textContent = 'New Project';
      document.getElementById('submit-text').textContent = 'Create Project';
      document.getElementById('project-form').reset();
      document.getElementById('edit-project-id').value = '';
      document.getElementById('start-date').value = new Date().toISOString().split('T')[0];
      document.getElementById('project-modal').classList.remove('hidden');
    }
    
    function closeProjectModal() {
      document.getElementById('project-modal').classList.add('hidden');
    }
    
    function editProject(backendId) {
      const project = projects.find(p => p.__backendId === backendId);
      if (!project) return;
      
      isEditing = true;
      document.getElementById('modal-title').textContent = 'Edit Project';
      document.getElementById('submit-text').textContent = 'Update Project';
      document.getElementById('edit-project-id').value = backendId;
      
      document.getElementById('project-id').value = project.project_id;
      document.getElementById('isbn').value = project.isbn || '';
      document.getElementById('title').value = project.title;
      document.getElementById('client').value = project.client;
      document.getElementById('manuscript-type').value = project.manuscript_type;
      document.getElementById('start-date').value = project.start_date;
      document.getElementById('due-date').value = project.due_date;
      document.getElementById('assigned-pe').value = project.assigned_pe;
      document.getElementById('current-stage').value = project.current_stage;
      document.getElementById('status').value = project.status;
      
      document.getElementById('project-modal').classList.remove('hidden');
    }
    
    async function handleProjectSubmit(event) {
      event.preventDefault();
      
      if (projects.length >= 999 && !isEditing) {
        showToast('Maximum limit of 999 projects reached. Please delete some projects first.', 'error');
        return;
      }
      
      const submitBtn = document.getElementById('submit-btn');
      const submitText = document.getElementById('submit-text');
      const submitSpinner = document.getElementById('submit-spinner');
      
      submitBtn.disabled = true;
      submitSpinner.classList.remove('hidden');
      submitText.textContent = isEditing ? 'Updating...' : 'Creating...';
      
      /*
      const projectData = {
        project_id: document.getElementById('project-id').value,
        isbn: document.getElementById('isbn').value,
        title: document.getElementById('title').value,
        client: document.getElementById('client').value,
        manuscript_type: document.getElementById('manuscript-type').value,
        start_date: document.getElementById('start-date').value,
        due_date: document.getElementById('due-date').value,
        assigned_pe: document.getElementById('assigned-pe').value,
        current_stage: document.getElementById('current-stage').value,
        status: document.getElementById('status').value
      };
      
      let result;
      if (isEditing) {
        const backendId = document.getElementById('edit-project-id').value;
        const existingProject = projects.find(p => p.__backendId === backendId);
        result = await window.dataSdk.update({
          ...existingProject,
          ...projectData
        });
      } else {
        projectData.id = Date.now().toString();
        projectData.created_at = new Date().toISOString();
        result = await window.dataSdk.create(projectData);
      }
      */
      
      // Mock result
      await new Promise(r => setTimeout(r, 1000));
      
      submitBtn.disabled = false;
      submitSpinner.classList.add('hidden');
      submitText.textContent = isEditing ? 'Update Project' : 'Create Project';
      
      showToast('Backend integration required to save changes.', 'info');
      /*
      if (result.isOk) {
        closeProjectModal();
        showToast(isEditing ? 'Project updated successfully!' : 'Project created successfully!', 'success');
      } else {
        showToast('Failed to save project. Please try again.', 'error');
      }
      */
    }
    
    function openDeleteModal(backendId) {
      const project = projects.find(p => p.__backendId === backendId);
      if (!project) return;
      
      projectToDelete = project;
      document.getElementById('delete-project-title').textContent = project.title;
      document.getElementById('delete-modal').classList.remove('hidden');
    }
    
    function closeDeleteModal() {
      document.getElementById('delete-modal').classList.add('hidden');
      projectToDelete = null;
    }
    
    async function confirmDelete() {
      if (!projectToDelete) return;
      
      const deleteBtn = document.getElementById('confirm-delete-btn');
      const deleteSpinner = document.getElementById('delete-spinner');
      
      deleteBtn.disabled = true;
      deleteSpinner.classList.remove('hidden');
      
      /*
      const result = await window.dataSdk.delete(projectToDelete);
      */
      
      // Mock result
      await new Promise(r => setTimeout(r, 1000));
      
      deleteBtn.disabled = false;
      deleteSpinner.classList.add('hidden');
      
      closeDeleteModal();
      showToast('Backend integration required to delete projects.', 'info');
      
      /*
      if (result.isOk) {
        closeDeleteModal();
        showToast('Project deleted successfully!', 'success');
      } else {
        showToast('Failed to delete project. Please try again.', 'error');
      }
      */
    }
    
    // Toast Notifications
    function showToast(message, type = 'info') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      
      const colors = {
        success: 'bg-emerald-500',
        error: 'bg-rose-500',
        info: 'bg-blue-500'
      };
      
      toast.className = `toast ${colors[type]} text-white px-6 py-3 rounded-xl shadow-lg flex items-center gap-3`;
      toast.innerHTML = `
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          ${type === 'success' ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>' : 
            type === 'error' ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>' :
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>'}
        </svg>
        <span>${escapeHtml(message)}</span>
      `;
      
      container.appendChild(toast);
      
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(100%)';
        toast.style.transition = 'all 0.3s ease';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }
    
    // Utility Functions
    function escapeHtml(text) {
      if (!text) return '';
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
    
    function formatDate(dateStr) {
      if (!dateStr) return 'N/A';
      const date = new Date(dateStr);
      return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }
    
    function getTypeClass(type) {
      const classes = {
        'Book': 'bg-blue-100 text-blue-700',
        'Chapter': 'bg-violet-100 text-violet-700',
        'Journal': 'bg-teal-100 text-teal-700'
      };
      return classes[type] || 'bg-slate-100 text-slate-700';
    }
    
    function getStageClass(stage) {
      const classes = {
        'Received': 'bg-slate-100 text-slate-700',
        'Copyediting': 'bg-blue-100 text-blue-700',
        'Typesetting': 'bg-violet-100 text-violet-700',
        'Proofing': 'bg-amber-100 text-amber-700',
        'Final QC': 'bg-teal-100 text-teal-700',
        'Completed': 'bg-emerald-100 text-emerald-700'
      };
      return classes[stage] || 'bg-slate-100 text-slate-700';
    }
    
    function getStatusClass(status) {
      const classes = {
        'Not Started': 'bg-slate-100 text-slate-700',
        'In Progress': 'bg-blue-100 text-blue-700',
        'On Hold': 'bg-amber-100 text-amber-700',
        'With Author': 'bg-violet-100 text-violet-700',
        'Completed': 'bg-emerald-100 text-emerald-700',
        'Delayed': 'bg-rose-100 text-rose-700'
      };
      return classes[status] || 'bg-slate-100 text-slate-700';
    }
    
    // Initialize
    applyConfig();
  </script>
</body>
</html>