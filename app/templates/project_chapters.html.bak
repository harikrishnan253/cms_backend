{% extends "base.html" %}

{% block title %}{{ project.title }} - Explorer{% endblock %}

{% block content %}
<div class="explorer-container">
    <!-- Ribbon / Toolbar -->
    <div class="explorer-toolbar">
        <div class="btn-group me-3">
            <button class="btn btn-sm btn-light border-0" onclick="history.back()"><i
                    class="fas fa-arrow-left"></i></button>
            <button class="btn btn-sm btn-light border-0" onclick="history.forward()"><i
                    class="fas fa-arrow-right"></i></button>
            <button class="btn btn-sm btn-light border-0" onclick="window.location.reload()"><i
                    class="fas fa-sync-alt"></i></button>
        </div>

        <!-- Address Bar -->
        <div class="explorer-address-bar rounded">
            <i class="fas fa-folder text-warning me-2"></i>
            <span>Projects <i class="fas fa-chevron-right mx-1 text-muted"></i> {{ project.code }}</span>
        </div>

        <!-- Search (Visual Only) -->
        <div class="input-group input-group-sm" style="width: 200px;">
            <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0" placeholder="Search {{ project.code }}">
        </div>
    </div>

    <!-- Command Bar -->
    <div class="explorer-toolbar py-1 bg-white border-bottom">
        <button class="btn btn-sm btn-link text-dark text-decoration-none" data-bs-toggle="modal"
            data-bs-target="#newChapterModal">
            <i class="fas fa-folder-plus text-warning me-1"></i> New Chapter
        </button>
        <div class="vr mx-2"></div>
        <button class="btn btn-sm btn-link text-dark text-decoration-none" id="viewToggleBtn">
            <i class="fas fa-list me-1"></i> View
        </button>
        <div class="vr mx-2"></div>
        {% if 'ProjectManager' in user.roles or 'Admin' in user.roles %}
        <form action="/projects/{{ project.id }}/delete" method="post" class="d-inline"
            onsubmit="return confirm('Delete Project?');">
            <button type="submit" class="btn btn-sm btn-link text-danger text-decoration-none">
                <i class="fas fa-trash me-1"></i> Delete Project
            </button>
        </form>
        {% endif %}
    </div>

    <!-- Main Explorer Body -->
    <div class="explorer-body">
        <!-- Sidebar -->
        <div class="explorer-sidebar">
            <div class="text-muted small px-3 mb-2 mt-2">Quick Access</div>
            <a href="/dashboard" class="nav-tree-item">
                <i class="fas fa-home text-primary"></i> Dashboard
            </a>
            <a href="#" class="nav-tree-item">
                <i class="fas fa-clock text-info"></i> Recent
            </a>

            <div class="text-muted small px-3 mb-2 mt-3">This PC</div>
            <a href="#" class="nav-tree-item active">
                <i class="fas fa-hdd text-secondary"></i> {{ project.code }}
            </a>
        </div>

        <!-- Main Content Area -->
        <div class="explorer-main" id="mainContentArea">
            <!-- Grid View Container -->
            <div class="explorer-grid" id="gridViewContainer">
                {% for chapter in chapters %}
                <div class="explorer-grid-item position-relative group-action-container">
                    <!-- Context Menu -->
                    <div class="dropdown position-absolute top-0 end-0 mt-1 me-1" style="z-index: 10;">
                        <button class="btn btn-sm btn-light p-0 border-0" type="button" data-bs-toggle="dropdown"
                            onclick="event.stopPropagation();" style="width: 20px; height: 20px; font-size: 0.7rem;">
                            <i class="fas fa-ellipsis-v text-muted"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><a class="dropdown-item" href="#" data-bs-toggle="modal"
                                    data-bs-target="#renameChapterModal{{ chapter.id }}"
                                    onclick="event.stopPropagation();"><i class="fas fa-edit me-2"></i>Rename</a></li>
                            <li><a class="dropdown-item"
                                    href="/projects/{{ project.id }}/chapter/{{ chapter.id }}/download"
                                    onclick="event.stopPropagation();"><i class="fas fa-download me-2"></i>Download
                                    ZIP</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <form action="/projects/{{ project.id }}/chapter/{{ chapter.id }}/delete" method="post"
                                    onsubmit="event.stopPropagation(); return confirm('Delete Chapter {{ chapter.number }}?');">
                                    <button type="submit" class="dropdown-item text-danger"><i
                                            class="fas fa-trash me-2"></i>Delete</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                    <div onclick="window.location.href='/projects/{{ project.id }}/chapter/{{ chapter.id }}'"
                        style="cursor: pointer; width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: flex-start;">
                        <i class="fas fa-folder explorer-icon-large"></i>
                        <div class="explorer-item-name">Chapter {{ chapter.number }}</div>
                        <small class="text-muted">{{ chapter.title|truncate(15) }}</small>
                    </div>
                </div>
                {% endfor %}

                {% if not chapters %}
                <div class="w-100 text-center py-5 text-muted">
                    <i class="fas fa-folder-open fa-3x mb-3 opacity-25"></i>
                    <p>No chapters found.</p>
                </div>
                {% endif %}
            </div>

            <!-- List View Container (Hidden by default) -->
            <table class="explorer-table d-none" id="listViewContainer">
                <thead>
                    <tr>
                        <th width="40%">Name</th>
                        <th width="20%">Date Modified</th>
                        <th width="20%">Type</th>
                        <th width="20%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for chapter in chapters %}
                    <tr>
                        <td onclick="window.location.href='/projects/{{ project.id }}/chapter/{{ chapter.id }}'"
                            style="cursor: pointer;">
                            <i class="fas fa-folder text-warning me-2"></i> Chapter {{ chapter.number }}
                        </td>
                        <td onclick="window.location.href='/projects/{{ project.id }}/chapter/{{ chapter.id }}'"
                            style="cursor: pointer;">{{ current_date }}</td>
                        <td onclick="window.location.href='/projects/{{ project.id }}/chapter/{{ chapter.id }}'"
                            style="cursor: pointer;">File Folder</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <button type="button" class="btn btn-light dropdown-toggle" data-bs-toggle="dropdown"
                                    data-bs-auto-close="true" data-bs-container="body" aria-expanded="false">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li><a class="dropdown-item" href="#" data-bs-toggle="modal"
                                            data-bs-target="#renameChapterModal{{ chapter.id }}"><i
                                                class="fas fa-edit me-2"></i>Rename</a></li>
                                    <li><a class="dropdown-item"
                                            href="/projects/{{ project.id }}/chapter/{{ chapter.id }}/download"><i
                                                class="fas fa-download me-2"></i>Download ZIP</a></li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <form action="/projects/{{ project.id }}/chapter/{{ chapter.id }}/delete"
                                            method="post"
                                            onsubmit="return confirm('Delete Chapter {{ chapter.number }}?');"><button
                                                type="submit" class="dropdown-item text-danger"><i
                                                    class="fas fa-trash me-2"></i>Delete</button></form>
                                    </li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Status Bar -->
    <div class="explorer-status-bar">
        <span>{{ chapters|length }} item(s)</span>
        <span>Online</span>
    </div>
</div>

<!-- New Chapter Modal -->
<div class="modal fade" id="newChapterModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form action="/projects/{{ project.id }}/chapters/create" method="post">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-bold">
                        <i class="fas fa-folder-plus me-2 text-warning"></i>Create New Chapter
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Chapter Number</label>
                        <input type="text" name="number" class="form-control" placeholder="e.g. 01, 02, 03..." required>
                        <small class="text-muted">Use format: 01, 02, etc.</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Chapter Title</label>
                        <input type="text" name="title" class="form-control" placeholder="e.g. Introduction" required>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i>Create Chapter
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Rename Chapter Modals -->
{% for chapter in chapters %}
<div class="modal fade" id="renameChapterModal{{ chapter.id }}" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form action="/projects/{{ project.id }}/chapter/{{ chapter.id }}/rename" method="post">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-bold">
                        <i class="fas fa-edit me-2 text-primary"></i>Rename Chapter
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Chapter Number</label>
                        <input type="text" name="number" class="form-control" value="{{ chapter.number }}" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Chapter Title</label>
                        <input type="text" name="title" class="form-control" value="{{ chapter.title }}" required>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Save Changes
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endfor %}

<script>
    // View Toggle Logic
    const viewBtn = document.getElementById('viewToggleBtn');
    const gridView = document.getElementById('gridViewContainer');
    const listView = document.getElementById('listViewContainer');
    let isGrid = true;

    if (viewBtn) {
        viewBtn.addEventListener('click', () => {
            isGrid = !isGrid;
            if (isGrid) {
                gridView.classList.remove('d-none');
                listView.classList.add('d-none');
                viewBtn.innerHTML = '<i class="fas fa-list me-1"></i> View';
            } else {
                gridView.classList.add('d-none');
                listView.classList.remove('d-none');
                viewBtn.innerHTML = '<i class="fas fa-th-large me-1"></i> View';
            }
        });
    }

    // Initialize Bootstrap dropdowns
    document.addEventListener('DOMContentLoaded', function () {
        // Initialize all dropdowns
        var dropdownElementList = [].slice.call(document.querySelectorAll('[data-bs-toggle="dropdown"]'));
        var dropdownList = dropdownElementList.map(function (dropdownToggleEl) {
            return new bootstrap.Dropdown(dropdownToggleEl);
        });

        console.log('Initialized', dropdownList.length, 'dropdowns');

        // Add event listeners for dropdown show/hide to manage z-index
        dropdownElementList.forEach(function (dropdown) {
            dropdown.addEventListener('show.bs.dropdown', function () {
                var row = this.closest('tr');
                if (row) {
                    row.classList.add('dropdown-active');
                }
            });

            dropdown.addEventListener('hide.bs.dropdown', function () {
                var row = this.closest('tr');
                if (row) {
                    row.classList.remove('dropdown-active');
                }
            });
        });
    });
</script>

<style>
    /* Override base container styles */
    .container,
    .container-fluid {
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    /* Windows Explorer Theme - Inlined */
    .explorer-container {
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 72px;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ffffff;
        font-family: 'Segoe UI', sans-serif;
        overflow: hidden;
        z-index: 1000;
        border-top: 1px solid #d9d9d9;
    }

    .explorer-toolbar {
        background-color: #f9f9f9;
        border-bottom: 1px solid #dadada;
        padding: 6px 12px;
        display: flex;
        gap: 10px;
        align-items: center;
        flex-shrink: 0;
    }

    .explorer-address-bar {
        display: flex;
        align-items: center;
        background: white;
        border: 1px solid #d9d9d9;
        padding: 3px 10px;
        flex-grow: 1;
        margin: 0 10px;
        height: 30px;
        font-size: 0.9rem;
        color: #333;
    }

    .explorer-body {
        display: flex;
        flex: 1;
        overflow: hidden;
        position: relative;
        background-color: #fff;
    }

    .explorer-sidebar {
        width: 260px;
        background-color: #f0f0f0;
        border-right: 1px solid #dadada;
        overflow-y: auto;
        padding: 10px 0;
        flex-shrink: 0;
    }

    .explorer-main {
        flex: 1;
        background-color: white;
        overflow-y: auto;
        padding: 10px;
        position: relative;
    }

    .nav-tree-item {
        display: flex;
        align-items: center;
        padding: 4px 15px;
        color: #333 !important;
        text-decoration: none;
        font-size: 0.9rem;
        cursor: default;
        user-select: none;
    }

    .nav-tree-item:hover {
        background-color: #e5f3ff;
        color: #000 !important;
    }

    .nav-tree-item.active {
        background-color: #cce8ff;
        border: 1px solid #99d1ff;
        color: #000 !important;
    }

    .nav-tree-item i {
        margin-right: 8px;
        color: #e8c763;
        width: 16px;
        text-align: center;
    }

    .explorer-grid {
        display: flex;
        flex-wrap: wrap;
        padding: 5px;
        gap: 2px;
        align-content: flex-start;
    }

    .explorer-grid-item {
        width: 90px;
        height: 100px;
        padding: 5px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        text-align: center;
        cursor: default;
        border: 1px solid transparent;
        margin-bottom: 5px;
        border-radius: 2px;
    }

    .explorer-grid-item:hover {
        background-color: #e5f3ff;
        border: 1px solid #cce8ff;
    }

    .explorer-icon-large {
        font-size: 42px;
        margin-bottom: 4px;
        color: #e8c763;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    }

    .explorer-item-name {
        font-size: 0.8rem;
        line-height: 1.1;
        word-break: break-word;
        width: 100%;
        color: #333;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .explorer-status-bar {
        background-color: #f5f6f7;
        border-top: 1px solid #dadada;
        padding: 4px 12px;
        font-size: 0.8rem;
        color: #333;
        display: flex;
        gap: 20px;
        flex-shrink: 0;
    }

    /* File Icons */
    .file-icon-word {
        color: #2b579a;
    }

    .file-icon-pdf {
        color: #d32f2f;
    }

    .file-icon-indesign {
        color: #d6006f;
    }

    .file-icon-xml {
        color: #f57f17;
    }

    /* Explorer Table (List View) */
    .explorer-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
    }

    .explorer-table thead {
        background-color: #f9f9f9;
        border-bottom: 1px solid #dadada;
    }

    .explorer-table th {
        padding: 8px 12px;
        text-align: left;
        font-weight: 600;
        color: #333;
        font-size: 0.85rem;
    }

    .explorer-table td {
        padding: 6px 12px;
        border-bottom: 1px solid #f0f0f0;
        vertical-align: middle;
    }

    .explorer-table tbody tr:hover {
        background-color: #e5f3ff;
    }

    .explorer-table tbody tr {
        transition: background-color 0.1s;
        position: relative;
    }

    .explorer-table tbody tr:hover {
        z-index: 100;
    }

    /* Fix for dropdown in table */
    .explorer-table tbody tr.dropdown-active {
        z-index: 1000 !important;
    }

    .explorer-table .dropdown-menu {
        z-index: 9999 !important;
    }
</style>
{% endblock %}